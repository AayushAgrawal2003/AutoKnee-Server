Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.5
    Tree Height: 442
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    # ── Grid (spatial reference) ──
    - Alpha: 0.3
      Cell Size: 0.1
      Class: rviz_default_plugins/Grid
      Color: 120; 120; 120
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 20
      Reference Frame: lbr_link_0
      Value: true
    # ── Robot Model ──
    - Alpha: 1
      Class: rviz_default_plugins/RobotModel
      Collision Enabled: false
      Description File: ""
      Description Source: Topic
      Description Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /lbr/robot_description
      Enabled: true
      Links:
        All Links Enabled: true
        Expand Joint Details: false
        Expand Link Details: false
        Expand Tree: false
        Link Tree Style: Links in Alphabetic Order
        lbr_floating_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        lbr_link_0:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_1:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_2:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_3:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_4:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_5:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_6:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_7:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        lbr_link_ee:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
      Mass Properties:
        Inertia: false
        Mass: false
      Name: Robot Model
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true
    # ── TF Tree ──
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Scale: 0.20000000298023224
      Name: TF
      Show Arrows: false
      Show Axes: true
      Show Names: false
      Update Interval: 0
      Value: true
    # ── Camera RGB ──
    - Class: rviz_default_plugins/Image
      Enabled: true
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Camera RGB
      Normalize Range: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /camera_arm/camera/color/image_rect_raw
      Value: true
    # ── Live Depth PointCloud ──
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 255; 255; 255
      Color Transformer: RGB8
      Decay Time: 1
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Live Depth
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.0001
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /camera_arm/camera/depth/color/points
      Use Fixed Frame: true
      Use rainbow: true
      Value: true
    # ══════════════════════════════════════════════════════════════════════
    # IR TRACKER POSES (from ir_tracking_node)
    # ══════════════════════════════════════════════════════════════════════
    # ── Femur Tracker Pose ──
    - Axes Length: 0.10000000149011612
      Axes Radius: 0.009999999776482582
      Class: rviz_default_plugins/Pose
      Color: 255; 120; 0
      Enabled: true
      Head Length: 0.015000000000000001
      Head Radius: 0.007000000000000001
      Name: Femur Tracker
      Shaft Length: 0.05000000000000001
      Shaft Radius: 0.004000000000000001
      Shape: Axes
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /kuka_frame/bone_pose_femur
      Value: true
    # ── Tibia Tracker Pose ──
    - Axes Length: 0.10000000149011612
      Axes Radius: 0.009999999776482582
      Class: rviz_default_plugins/Pose
      Color: 0; 220; 100
      Enabled: true
      Head Length: 0.015000000000000001
      Head Radius: 0.007000000000000001
      Name: Tibia Tracker
      Shaft Length: 0.05000000000000001
      Shaft Radius: 0.004000000000000001
      Shape: Axes
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /kuka_frame/bone_pose_tibia
      Value: true
    # ── EE Tracker Pose (IR) ──
    - Axes Length: 0.10000000149011612
      Axes Radius: 0.009999999776482582
      Class: rviz_default_plugins/Pose
      Color: 0; 150; 255
      Enabled: true
      Head Length: 0.015000000000000001
      Head Radius: 0.007000000000000001
      Name: EE Tracker (IR)
      Shaft Length: 0.05000000000000001
      Shaft Radius: 0.004000000000000001
      Shape: Axes
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /kuka_frame/pose_ee
      Value: true
    # ══════════════════════════════════════════════════════════════════════
    # TRACKED BONE CLOUDS (/tracked/*) — live output from bone_cloud_mover
    # bone_cloud_mover publishes one topic per bone: /tracked/{bone}
    # ══════════════════════════════════════════════════════════════════════
    # ── Tracked Femur ──
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 200; 80; 0
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Tracked Femur
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.003000000026077032
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /tracked/femur
      Use Fixed Frame: true
      Use rainbow: false
      Value: true
    # ── Tracked Tibia ──
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 0; 180; 80
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Tracked Tibia
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.003000000026077032
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /tracked/tibia
      Use Fixed Frame: true
      Use rainbow: false
      Value: true
    # ══════════════════════════════════════════════════════════════════════
    # STATIC CLOUDS (latched, set once after ICP — disabled by default)
    #   /bone_scan/*  — filtered+denoised camera scan clouds
    #   /bone_model/* — ICP-aligned reference PLY (model moved to match scan)
    # ══════════════════════════════════════════════════════════════════════
    # ── Bone Scan Tibia (static) ──
    - Alpha: 0.6
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 0; 255; 100
      Color Transformer: RGB8
      Decay Time: 2
      Enabled: false
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Bone Scan Tibia (static)
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.003000000026077032
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /bone_scan/tibia
      Use Fixed Frame: true
      Use rainbow: false
      Value: false
    # ── Bone Model Tibia (static) ──
    - Alpha: 0.3
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 0; 180; 80
      Color Transformer: FlatColor
      Decay Time: 2
      Enabled: false
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Bone Model Tibia (static)
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 2
      Size (m): 0.0020000000949949026
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /bone_model/tibia
      Use Fixed Frame: true
      Use rainbow: false
      Value: false
    # ── Bone Scan Femur (static) ──
    - Alpha: 0.6
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 255; 100; 0
      Color Transformer: RGB8
      Decay Time: 2
      Enabled: false
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Bone Scan Femur (static)
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.003000000026077032
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /bone_scan/femur
      Use Fixed Frame: true
      Use rainbow: false
      Value: false
    # ── Bone Model Femur (static) ──
    - Alpha: 0.3
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 200; 80; 0
      Color Transformer: FlatColor
      Decay Time: 2
      Enabled: false
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Bone Model Femur (static)
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 2
      Size (m): 0.0020000000949949026
      Style: Flat Squares
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /bone_model/femur
      Use Fixed Frame: true
      Use rainbow: false
      Value: false
  Enabled: true
  Global Options:
    Background Color: 35; 35; 35
    Fixed Frame: lbr_link_0
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetInitialPose
      Covariance x: 0.25
      Covariance y: 0.25
      Covariance yaw: 0.06853891909122467
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: initialpose
    - Class: rviz_default_plugins/SetGoal
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: goal_pose
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 2.5
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 0
        Y: 0
        Z: 0.5
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.30000001192092896
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz_default_plugins)
      Yaw: 1.5699999332427979
    Saved: ~
Window Geometry:
  Camera RGB:
    collapsed: false
  Displays:
    collapsed: false
  Height: 946
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Views:
    collapsed: false
  Width: 1920
  X: 0
  Y: 27
